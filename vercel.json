{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "client/dist",
  "routes": [
    {
      "src": "/api/ml/health",
      "dest": "/api/ml/health.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...all].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
